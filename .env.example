# Enterprise Agent OS
# Copy this file to `.env` and adjust values for your local environment.

# ── Runtime ──────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/v1

# ── Model Routing ────────────────────────────────────────
# `single` = one provider per role
# `hybrid` = one provider per role + optional fallback provider
MODEL_ROUTING_MODE=hybrid
MODEL_FALLBACK_PROVIDER=ollama
MODEL_PLANNER_PROVIDER=gemini
MODEL_WORKER_PROVIDER=gemini
MODEL_CLASSIFIER_PROVIDER=gemini

# Frontend-visible model labels
NEXT_PUBLIC_MODEL_ROUTING_MODE=hybrid
NEXT_PUBLIC_MODEL_FALLBACK_PROVIDER=ollama
NEXT_PUBLIC_MODEL_PLANNER_PROVIDER=gemini
NEXT_PUBLIC_MODEL_WORKER_PROVIDER=gemini
NEXT_PUBLIC_MODEL_CLASSIFIER_PROVIDER=gemini

# ── Anthropic (optional) ─────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_MODEL_PLANNER=claude-opus-4-5-20250514
ANTHROPIC_MODEL_WORKER=claude-sonnet-4-5-20250514
ANTHROPIC_MODEL_CLASSIFIER=claude-haiku-4-5-20251001
NEXT_PUBLIC_ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── OpenAI (optional) ───────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL_PLANNER=gpt-4o
OPENAI_MODEL_WORKER=gpt-4o-mini
OPENAI_MODEL_CLASSIFIER=gpt-4o-mini

# ── Gemini (recommended if you only have a Gemini key) ──
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL_PLANNER=gemini-2.5-pro
GEMINI_MODEL_WORKER=gemini-2.5-flash
GEMINI_MODEL_CLASSIFIER=gemini-2.5-flash-lite
NEXT_PUBLIC_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ── Mistral (optional) ──────────────────────────────────
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai
MISTRAL_MODEL_PLANNER=mistral-large-latest
MISTRAL_MODEL_WORKER=mistral-medium-latest
MISTRAL_MODEL_CLASSIFIER=mistral-small-latest

# ── Cohere (optional) ───────────────────────────────────
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.com
COHERE_MODEL_PLANNER=command-r-plus
COHERE_MODEL_WORKER=command-r
COHERE_MODEL_CLASSIFIER=command-r

# ── Groq (optional) ─────────────────────────────────────
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai
GROQ_MODEL_PLANNER=llama-3.3-70b-versatile
GROQ_MODEL_WORKER=llama-3.1-8b-instant
GROQ_MODEL_CLASSIFIER=llama-3.1-8b-instant

# ── Together (optional) ─────────────────────────────────
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz
TOGETHER_MODEL_PLANNER=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
TOGETHER_MODEL_WORKER=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
TOGETHER_MODEL_CLASSIFIER=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# ── Azure OpenAI (optional) ─────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT_PLANNER=gpt-4o
AZURE_OPENAI_DEPLOYMENT_WORKER=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_CLASSIFIER=gpt-4o-mini

# ── Ollama (optional local fallback / hybrid mode) ──────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_MODEL_PLANNER=qwen3-coder
OLLAMA_MODEL_WORKER=qwen3-coder
OLLAMA_MODEL_CLASSIFIER=gemma3
NEXT_PUBLIC_OLLAMA_BASE_URL=http://localhost:11434

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agent_os:agent_os_dev@localhost:5432/agent_os
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# ── Qdrant ───────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── NATS ─────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_CREDENTIALS=

# ── Vault (dev mode) ─────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# ── Object Storage ───────────────────────────────────────
S3_BUCKET_ARTIFACTS=agent-os-artifacts-dev
S3_BUCKET_AUDIT_ARCHIVE=agent-os-audit-dev
AWS_REGION=us-east-1

# ── Internal Services ────────────────────────────────────
GOVERNANCE_PROXY_URL=http://localhost:8090
TOOL_REGISTRY_URL=http://localhost:8000/v1/tools

# ── Governance ───────────────────────────────────────────
INJECTION_DETECTION_THRESHOLD=0.6
MAX_RUN_STEPS_DEFAULT=25
MAX_RUN_TIME_SECONDS_DEFAULT=600
MAX_TOOL_CALLS_DEFAULT=50

# ── Observability ────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agent-os-api
SENTRY_DSN=

# ── Auth / Security ──────────────────────────────────────
JWT_PUBLIC_KEY=dev-key
ENCRYPTION_KEY=dev-encryption-key
